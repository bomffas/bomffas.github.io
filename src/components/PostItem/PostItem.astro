---
import "./PostItem.css";

import { Image } from "astro:assets";
import FormattedDate from "@components/FormattedDate.astro";

interface IPostItem {
  heroImage: string;
  id: string;
  title: string;
  date: Date;
}

const { heroImage, id, title, date } = Astro.props as IPostItem;
---

<li class="post-item">
  <a
    class="post-item__link"
    href={`/blog/${id}/`}
    title=`Read the text: ${title}`
    data-post-id={id}
    data-post-title={title}
  >
    <div class="post-item__cover">
      {
        heroImage && (
          <Image
            width={720}
            height={360}
            src={heroImage}
            alt={title}
            class="post-item__img"
          />
        )
      }
    </div>
    <p class="heading-three post-item__title">{title}</p>
    <span class="heading-three post-item__date"
      ><FormattedDate date={date} /></span
    >
  </a>
</li>

<script is:inline>
  document.addEventListener("DOMContentLoaded", function () {
    document
      .querySelectorAll(".post-item__link[data-post-id]")
      .forEach(function (link) {
        link.addEventListener("click", function () {
          window.posthog?.capture("blog_post_clicked", {
            post_id: link.getAttribute("data-post-id"),
            post_title: link.getAttribute("data-post-title"),
          });
        });
      });
  });
</script>
